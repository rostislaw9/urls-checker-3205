{
  "name": "urls-checker-3205",
  "version": "0.0.1",
  "private": true,
  "description": "URLs Checker - asynchronous URL checking application",
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "prepare": "husky",
    "lint:backend": "cd backend && yarn lint:check",
    "lint:frontend": "cd frontend && yarn lint:check",
    "format:backend": "cd backend && yarn format:check",
    "format:frontend": "cd frontend && yarn format:check",
    "test:backend": "cd backend && yarn test",
    "test:frontend": "cd frontend && yarn test",
    "build:backend": "cd backend && yarn build",
    "build:frontend": "cd frontend && yarn build"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "cd backend && yarn prettier --write",
      "cd backend && yarn eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "cd frontend && yarn prettier --write",
      "cd frontend && yarn eslint --fix"
    ]
  }
}
